# Base URL of diving-api (Next.js). No trailing slash.
# MUST match diving-api BETTER_AUTH_URL host (use 127.0.0.1 on simulator, not localhost).
# Simulator: http://127.0.0.1:3000
# Physical device: http://YOUR_LAN_IP:3000
EXPO_PUBLIC_AUTH_URL=http://127.0.0.1:3000

# Web OAuth client ID (same value as diving-api GOOGLE_CLIENT_ID) — required for native Google Sign-In on Android
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Required for native Google Sign-In on iOS dev builds (rebuild app after setting)
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=